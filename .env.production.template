# Production Environment Template
# Copy this to .env.production and fill in your values
# NEVER commit this file to version control

# General Configuration
NODE_ENV=production

# Blockchain Configuration (CRITICAL - Use secure values)
PRIVATE_KEY=0xYOUR_MAINNET_PRIVATE_KEY_HERE
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
ETHERSCAN_API_KEY=your_production_etherscan_api_key

# Production Contract Addresses (Update after mainnet deployment)
AGENT_REGISTRY_ADDRESS=0xYOUR_MAINNET_REGISTRY_ADDRESS
AGENT_DELEGATION_ADDRESS=0xYOUR_MAINNET_DELEGATION_ADDRESS
DISPUTE_RESOLVER_ADDRESS=0xYOUR_MAINNET_DISPUTE_ADDRESS
AGENT_PROFILE_NFT_ADDRESS=0xYOUR_MAINNET_NFT_ADDRESS
STABLECOIN_ADDRESS=0x09Bc4E0D864854c6aFB8eB911061502D533A9608

# Backend Configuration
PORT=3001
BACKEND_URL=https://your-api-domain.com

# Frontend Configuration (Only expose necessary variables)
VITE_AGENT_REGISTRY_ADDRESS=0xYOUR_MAINNET_REGISTRY_ADDRESS
VITE_AGENT_DELEGATION_ADDRESS=0xYOUR_MAINNET_DELEGATION_ADDRESS
VITE_DISPUTE_RESOLVER_ADDRESS=0xYOUR_MAINNET_DISPUTE_ADDRESS
VITE_AGENT_PROFILE_NFT_ADDRESS=0xYOUR_MAINNET_NFT_ADDRESS
VITE_STABLECOIN_ADDRESS=0x09Bc4E0D864854c6aFB8eB911061502D533A9608
VITE_MAINNET_RPC_URL=https://rpc.mantle.xyz
VITE_NETWORK_NAME=mainnet

# Security Configuration
CORS_ORIGIN=https://your-frontend-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring & Logging
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=error

# Database (if using)
DATABASE_URL=your_production_database_url_here

# Redis (if using for caching)
REDIS_URL=your_redis_url_here

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_here
JWT_EXPIRES_IN=24h

# Additional Security Headers
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# SSL Configuration (if not using reverse proxy)
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem
